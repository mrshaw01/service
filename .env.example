# Copy this file to `.env` and fill in real values.
# Never commit `.env` (it is ignored by `.gitignore`).

# === Required: OpenAI-compatible inference gateway (curl) ===

# OpenAI-compatible base URL (MUST include `/v1`)
# Example: https://external.YOUR_REGION.tensormesh.ai/v1
OPENAI_BASE_URL=https://external.YOUR_REGION.tensormesh.ai/v1

# Bearer token used as: Authorization: Bearer <token>
TENSORMESH_API_KEY=

# Required by Tensormesh gateway for attribution/routing (sent as `X-User-Id`)
TENSORMESH_USER_ID=00000000-0000-0000-0000-000000000000

# Deployed model ID (use `/v1/models` to sanity check)
OPENAI_MODEL=your-deployed-model-id
